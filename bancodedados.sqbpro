	&quot;id_escala&quot;	INTEGER NOT NULL,
	&quot;id_profissional&quot;	INTEGER NOT NULL,
	&quot;id_plantao&quot;	INTEGER NOT NULL,
	&quot;status&quot;	VARCHAR(50) NOT NULL,
	&quot;data_alocacao&quot;	VARCHAR(50) NOT NULL,
	PRIMARY KEY(&quot;id_escala&quot; AUTOINCREMENT)
	CONSTRAINT &quot;fk_escala_profissional&quot; FOREIGN KEY(&quot;id_profissional&quot;) REFERENCES &quot;profissional&quot;(&quot;id_profissional&quot;)
	CONSTRAINT &quot;fk_escala_plantao&quot; FOREIGN KEY(&quot;id_plantao&quot;) REFERENCES &quot;plantao&quot;(&quot;id_plantao&quot;))</sql><current_tab id="0"/></tab_sql></sqlb_project>
